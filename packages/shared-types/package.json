{
  "name": "@slidebot/shared-types",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared TypeScript types for SlideBot — used by web, api, and extension",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scene-graph": {
      "types": "./dist/scene-graph.d.ts",
      "default": "./dist/scene-graph.js"
    },
    "./scene-graph-normalizer": {
      "types": "./dist/scene-graph-normalizer.d.ts",
      "default": "./dist/scene-graph-normalizer.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rimraf dist"
  },
  "devDependencies": {
    "@slidebot/tsconfig": "workspace:*",
    "rimraf": "^6.0.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "dependencies": {
    "zod": "^3.23.8"
  }
}
