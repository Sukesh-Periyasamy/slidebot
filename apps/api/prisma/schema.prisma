// This is the Prisma schema file for SlideBot.
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum DeckRole {
  owner
  editor
  viewer
}

enum AnnotationTool {
  freehand
  highlight
  arrow
  text
  laser
  select
  eraser
}

enum SessionStatus {
  waiting
  active
  ended
}

enum RoomStatus {
  active
  ended
}

enum RoomParticipantRole {
  presenter
  viewer
}

// ─────────────────────────────────────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  displayName String   @map("display_name")
  avatarUrl   String?  @map("avatar_url")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  ownedDecks     Deck[]
  collaborations DeckCollaborator[]
  annotations    Annotation[]
  sessions       PresentationSession[] @relation("SessionPresenter")
  presentedRooms Room[]               @relation("RoomPresenter")
  roomParticipants  RoomParticipant[]

  @@map("users")
}

model Deck {
  id          String   @id @default(cuid())
  ownerId     String
  name        String
  storagePath String   @default("")
  slides      Int      @default(1)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  owner         User                  @relation(fields: [ownerId], references: [id])
  rooms         Room[]
  slideEntities Slide[]
  collaborators DeckCollaborator[]
  sessions      PresentationSession[]

  @@index([ownerId])
  @@map("decks")
}

model Room {
  id          String   @id @default(uuid())
  deckId      String
  presenterId String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  endedAt     DateTime?

  deck         Deck              @relation(fields: [deckId], references: [id], onDelete: Cascade)
  presenter    User              @relation("RoomPresenter", fields: [presenterId], references: [id])
  participants RoomParticipant[]

  @@index([deckId])
  @@index([presenterId])
  @@map("rooms")
}

model RoomParticipant {
  roomId   String
  userId   String
  role     String   @default("viewer")
  joinedAt DateTime @default(now())
  leftAt   DateTime?

  room Room @relation(fields: [roomId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@id([roomId, userId])
  @@map("room_participants")
}

model Slide {
  id                 String   @id @default(uuid())
  deckId             String   @map("deck_id")
  /// Fractional position for ordering (gaps: 1000, 2000, 3000...)
  position           Int
  backgroundColor    String   @default("#FFFFFF") @map("background_color")
  backgroundImageUrl String?  @map("background_image_url")
  layoutMeta         Json     @default("{\"layout\":\"blank\"}") @map("layout_meta")
  deletedAt          DateTime? @map("deleted_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  // Relations
  deck                Deck                  @relation(fields: [deckId], references: [id], onDelete: Cascade)
  annotations         Annotation[]
  annotationSnapshot  AnnotationSnapshot?

  @@index([deckId, position])
  @@map("slides")
}

model DeckCollaborator {
  deckId     String   @map("deck_id")
  userId     String   @map("user_id")
  role       DeckRole @default(viewer)
  invitedAt  DateTime @default(now()) @map("invited_at")
  acceptedAt DateTime? @map("accepted_at")

  // Relations
  deck Deck @relation(fields: [deckId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([deckId, userId])
  @@map("deck_collaborators")
}

model Annotation {
  id          String         @id @default(uuid())
  slideId     String         @map("slide_id")
  /// Optional: groups annotation to a specific presentation session
  sessionId   String?        @map("session_id")
  userId      String         @map("user_id")
  displayName String         @default("") @map("display_name")
  tool        AnnotationTool
  color       String
  strokeWidth Float          @map("stroke_width")
  opacity     Float          @default(1.0)
  /// JSON payload — discriminated union per AnnotationData frontend type
  data        Json           @default("{}")
  isEphemeral Boolean        @default(false) @map("is_ephemeral")
  deletedAt   DateTime?      @map("deleted_at")
  createdAt   DateTime       @default(now()) @map("created_at")

  // Relations
  slide   Slide                @relation(fields: [slideId], references: [id], onDelete: Cascade)
  user    User                 @relation(fields: [userId], references: [id])
  session PresentationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([slideId])
  @@index([sessionId])
  @@index([slideId, deletedAt])
  @@map("annotations")
}

/// Pre-built JSON snapshot of all non-ephemeral annotations for a slide.
/// Regenerated whenever a non-ephemeral annotation is added/deleted.
/// Used for fast reconnect / rejoin restore (single SELECT instead of full scan).
model AnnotationSnapshot {
  id          String   @id @default(uuid())
  slideId     String   @unique @map("slide_id")
  sessionId   String?  @map("session_id")
  /// Full JSON array of Annotation objects
  payload     Json     @default("[]")
  annotationCount Int  @default(0) @map("annotation_count")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  slide   Slide                @relation(fields: [slideId], references: [id], onDelete: Cascade)
  session PresentationSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@map("annotation_snapshots")
}

model PresentationSession {
  id                String        @id @default(uuid())
  deckId            String        @map("deck_id")
  presenterId       String        @map("presenter_id")
  currentSlideIndex Int           @default(0) @map("current_slide_index")
  status            SessionStatus @default(waiting)
  startedAt         DateTime      @default(now()) @map("started_at")
  endedAt           DateTime?     @map("ended_at")

  // Relations
  deck                Deck                  @relation(fields: [deckId], references: [id])
  presenter           User                  @relation("SessionPresenter", fields: [presenterId], references: [id])
  annotations         Annotation[]
  annotationSnapshots AnnotationSnapshot[]

  @@index([deckId])
  @@map("presentation_sessions")
}
