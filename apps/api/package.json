{
  "name": "@slidebot/api",
  "version": "0.0.1",
  "private": true,
  "description": "SlideBot — Express + Socket.IO API server",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "test": "vitest run",
    "clean": "rimraf dist",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.21.0",
    "@slidebot/shared-schemas": "workspace:*",
    "@slidebot/shared-types": "workspace:*",
    "@slidebot/shared-utils": "workspace:*",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.45.4",
    "bullmq": "^5.17.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "express-rate-limit": "^7.4.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.1",
    "morgan": "^1.10.0",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "pino-pretty": "^11.3.0",
    "socket.io": "^4.8.0",
    "socket.io-redis": "^6.1.1",
    "yjs": "^13.6.20",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@slidebot/eslint-config": "workspace:*",
    "@slidebot/tsconfig": "workspace:*",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/ioredis-mock": "^8.2.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.7.5",
    "ioredis-mock": "^8.13.1",
    "prisma": "^5.21.0",
    "rimraf": "^6.0.1",
    "socket.io-client": "^4.8.0",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3"
  }
}
