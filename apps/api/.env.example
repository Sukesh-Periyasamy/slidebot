NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# Database (copy from Supabase project settings)
DATABASE_URL=postgresql://postgres:password@localhost:5432/slidebot
DIRECT_URL=postgresql://postgres:password@localhost:5432/slidebot

# Supabase (copy from Supabase dashboard > Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000

# JWT (generate with: openssl rand -base64 32)
JWT_SECRET=change-me-to-at-least-32-char-secret

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug

# Sentry (optional)
SENTRY_DSN=
