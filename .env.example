# ==============================================================================
# SlideBot — Environment Variables Reference
# Copy this file to .env in the relevant app directory
# ==============================================================================

# ------------------------------------------------------------------------------
# APP / WEB (apps/web/.env)
# ------------------------------------------------------------------------------
VITE_APP_NAME=SlideBot
VITE_API_URL=http://localhost:4000
VITE_WS_URL=ws://localhost:4000
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=

# ------------------------------------------------------------------------------
# API (apps/api/.env)
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
HOST=0.0.0.0

# --- Database ---
DATABASE_URL=postgresql://postgres:password@localhost:5432/slidebot
DIRECT_URL=postgresql://postgres:password@localhost:5432/slidebot

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# --- Redis (Upstash) ---
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,chrome-extension://your-extension-id

# --- JWT ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
LOG_LEVEL=debug

# --- Sentry ---
SENTRY_DSN=

# ------------------------------------------------------------------------------
# CHROME EXTENSION (apps/extension/.env)
# ------------------------------------------------------------------------------
VITE_EXT_API_URL=http://localhost:4000
VITE_EXT_WS_URL=ws://localhost:4000
VITE_EXT_SUPABASE_URL=https://your-project.supabase.co
VITE_EXT_SUPABASE_ANON_KEY=your-supabase-anon-key
